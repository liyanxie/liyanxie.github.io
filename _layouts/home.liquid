---
layout: default
---
<div class="home-page">
  <section class="home-hero" aria-label="Profile summary">
    <div class="home-photo">
      {% if page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        <img
          src="{{ profile_image_path | relative_url | bust_file_cache }}"
          class="home-profile-image z-depth-1 rounded"
          alt="{{ page.profile.alt }}"
          width="125"
          height="auto"
          loading="eager"
        >
      {% endif %}
    </div>

    <div class="home-intro">
      <h1>{{ page.name }}</h1>
      <p class="home-title">{{ page.position }}</p>

      <div class="home-affiliations">
        {% for affiliation in page.affiliations %}
          <p>
            {% if affiliation.url %}
              <a href="{{ affiliation.url }}">{{ affiliation.label }}</a>
            {% else %}
              {{ affiliation.label }}
            {% endif %}
          </p>
        {% endfor %}
      </div>

      <div class="home-links" aria-label="Profile links">
        {% if page.cv %}<a href="{{ page.cv | relative_url }}">CV</a>{% endif %}
        {% if page.google_scholar %}<a href="{{ page.google_scholar }}">Google Scholar</a>{% endif %}
        {% if page.linkedin %}<a href="{{ page.linkedin }}">LinkedIn</a>{% endif %}
      </div>

      {% if page.email %}
        <p class="home-email">E-Mail: <span>{{ page.email }}</span></p>
      {% endif %}
    </div>
  </section>

  <article class="home-body">
    {{ content }}
  </article>
</div>
