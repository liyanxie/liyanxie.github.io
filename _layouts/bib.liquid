---
---
{% assign paper_url = entry.pdf %}
{% if paper_url == blank %}
  {% assign paper_url = entry.html %}
{% endif %}
{% if paper_url == blank %}
  {% assign paper_url = entry.url %}
{% endif %}
{% if paper_url contains 'arxiv.org/abs/' %}
  {% assign paper_url = paper_url | replace: '/abs/', '/pdf/' %}
{% endif %}
{% assign paper_href = paper_url %}
{% if paper_url != blank %}
  {% unless paper_url contains '://' %}
    {% assign paper_href = paper_url | prepend: '/assets/pdf/' | relative_url %}
  {% endunless %}
{% endif %}
{% assign code_href = '' %}
{% assign code_label = '' %}
{% if entry.code %}
  {% if entry.code contains '://' %}
    {% assign code_href = entry.code %}
    {% if entry.code contains 'github.com' %}
      {% assign code_label = 'GitHub' %}
    {% else %}
      {% assign code_label = 'Code' %}
    {% endif %}
  {% else %}
    {% assign code_href = entry.code | prepend: '/assets/pdf/' | relative_url %}
    {% assign code_label = 'Code' %}
  {% endif %}
{% endif %}

<div
  id="{{ entry.key }}"
  class="publication-entry"
  data-year="{{ entry.year }}"
  data-topic="{{ entry.topic | default: 'other' }}"
  data-category="{{ entry.category | default: 'other' }}"
>
  <div class="publication-main">
    <div class="publication-title">
      {% if paper_href != blank %}
        <a class="publication-title-link" href="{{ paper_href }}">{{ entry.title }}</a>
      {% else %}
        {{ entry.title }}
      {% endif %}
      {% if code_href != blank %}
        <a class="publication-title-extra" href="{{ code_href }}">({{ code_label }})</a>
      {% endif %}
    </div>

    <div class="publication-authors">
      {% for author in entry.author_array %}
        {% assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' %}
        {% assign author_last_html = author.last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' %}
        {% assign author_is_self = false %}
        {% if site.scholar.last_name contains author_last_name and site.scholar.first_name contains author.first %}
          {% assign author_is_self = true %}
        {% endif %}
        {% unless forloop.first %}
          {% if forloop.last %}, and {% else %}, {% endif %}
        {% endunless %}
        {% if author_is_self %}
          <strong>{{ author.first }} {{ author_last_html }}</strong>
        {% else %}
          {{ author.first }} {{ author_last_html }}
        {% endif %}
      {% endfor %}
    </div>

    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}
    {% capture venue %}
      {% if entry.category == 'preprint' %}
        preprint
      {% elsif entry.type == 'article' %}
        {{ entry.journal }}
      {% elsif proceedings contains entry.type %}
        {{ entry.booktitle }}
      {% elsif thesis contains entry.type %}
        {{ entry.school }}
      {% elsif entry.howpublished %}
        {{ entry.howpublished }}
      {% endif %}
    {% endcapture %}
    {% assign venue = venue | strip %}
    {% if venue != blank or entry.year %}
      <div class="publication-venue">
        {% if venue != blank %}<em>{{ venue }}</em>{% endif %}{% if venue != blank and entry.year %}, {% endif %}{{ entry.year }}
      </div>
    {% endif %}

    {% if entry.note %}
      <div class="publication-note">{{ entry.note }}</div>
    {% endif %}

    {% if entry.doi or entry.bibtex_show %}
      <div class="publication-links">
        {% if entry.doi %}
          <a href="https://doi.org/{{ entry.doi }}">DOI</a>
        {% endif %}
        {% if entry.bibtex_show %}
          <a class="bibtex" role="button">BibTeX</a>
        {% endif %}
      </div>
    {% endif %}

    {% if entry.bibtex_show %}
      <div class="bibtex hidden">
        {% highlight bibtex %}
        {{- entry.bibtex | hideCustomBibtex -}}
        {% endhighlight %}
      </div>
    {% endif %}
  </div>
</div>
